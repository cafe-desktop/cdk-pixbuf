#: cdk-pixbuf/cdk-pixbuf-animation.c:190 cdk-pixbuf/cdk-pixbuf-io.c:1224
#: cdk-pixbuf/cdk-pixbuf-io.c:1497
#, c-format
msgid "Failed to open file “%s”: %s"
msgstr "“%s” faylini ochib bo‘lmadi: %s"

#: cdk-pixbuf/cdk-pixbuf-animation.c:203 cdk-pixbuf/cdk-pixbuf-io.c:1085
#, c-format
msgid "Image file “%s” contains no data"
msgstr "“%s” rasm faylida maʼlumotlar yoʻq"

#: cdk-pixbuf/cdk-pixbuf-animation.c:241
#, c-format
msgid ""
"Failed to load animation “%s”: reason not known, probably a corrupt "
"animation file"
msgstr ""
"'%s' : animatsiyasini yuklab boʻlmadi: sababi nomaʼlum, balki fayl buzuq "
"boʻlishi mumkin"

#: cdk-pixbuf/cdk-pixbuf-animation.c:309 cdk-pixbuf/cdk-pixbuf-io.c:1260
#: cdk-pixbuf/cdk-pixbuf-io.c:1549
#, c-format
msgid ""
"Failed to load image “%s”: reason not known, probably a corrupt image file"
msgstr ""
"'%s' rasmini yuklab boʻlmadi: sababi nomaʼlum, balki fayl buzuq boʻlishi "
"mumkin"

#: cdk-pixbuf/cdk-pixbuf.c:248
msgid "Number of Channels"
msgstr "Kanallar soni"

#: cdk-pixbuf/cdk-pixbuf.c:249
msgid "The number of samples per pixel"
msgstr "Bir piksel uchun namunalar soni"

#: cdk-pixbuf/cdk-pixbuf.c:264
msgid "Colorspace"
msgstr "Rang maydoni"

#: cdk-pixbuf/cdk-pixbuf.c:265
msgid "The colorspace in which the samples are interpreted"
msgstr "Namunalar talqin qilinadigan rang maydoni"

#: cdk-pixbuf/cdk-pixbuf.c:277
msgid "Has Alpha"
msgstr "Alfa bor"

#: cdk-pixbuf/cdk-pixbuf.c:278
msgid "Whether the pixbuf has an alpha channel"
msgstr "Pixbufda alfa kanali bormi"

#: cdk-pixbuf/cdk-pixbuf.c:291
msgid "Bits per Sample"
msgstr "Bitta namuna uchun"

#: cdk-pixbuf/cdk-pixbuf.c:292
msgid "The number of bits per sample"
msgstr "Bitta namunadagi bitlar soni"

#: cdk-pixbuf/cdk-pixbuf.c:305
msgid "Width"
msgstr "Kengligi"

#: cdk-pixbuf/cdk-pixbuf.c:306
msgid "The number of columns of the pixbuf"
msgstr "Pixbuf ustunlari soni"

#: cdk-pixbuf/cdk-pixbuf.c:319
msgid "Height"
msgstr "Balandligi"

#: cdk-pixbuf/cdk-pixbuf.c:320
msgid "The number of rows of the pixbuf"
msgstr "Pixbuf qatorlari soni"

#: cdk-pixbuf/cdk-pixbuf.c:337
msgid "Rowstride"
msgstr "Rowstride"

#: cdk-pixbuf/cdk-pixbuf.c:338
msgid ""
"The number of bytes between the start of a row and the start of the next row"
msgstr "Qator boshi va keyingi qator boshi orasidagi baytlar soni"

#: cdk-pixbuf/cdk-pixbuf.c:351
msgid "Pixels"
msgstr "Piksellar"

#: cdk-pixbuf/cdk-pixbuf.c:352
msgid "A pointer to the pixel data of the pixbuf"
msgstr "Pixbufning piksel ma'lumotlariga ko'rsatgich"

#: cdk-pixbuf/cdk-pixbuf.c:366
msgid "Pixel Bytes"
msgstr "Piksel bayt"

#: cdk-pixbuf/cdk-pixbuf.c:367
msgid "Readonly pixel data"
msgstr "Faqat o'qish uchun piksel ma'lumotlari"

#: cdk-pixbuf/cdk-pixbuf-io.c:901
#, c-format
msgid "Unable to load image-loading module: %s: %s"
msgstr "Rasm yuklash modulini yuklab boʻlmadi: %s: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:919
#, c-format
msgid ""
"Image-loading module %s does not export the proper interface; perhaps it’s "
"from a different cdk-pixbuf version?"
msgstr ""
"Rasmni yuklash moduli %s tegishli interfeysni eksport qilmaydi; ehtimol u "
"boshqa cdk-pixbuf versiyasidandir?"

#: cdk-pixbuf/cdk-pixbuf-io.c:929 cdk-pixbuf/cdk-pixbuf-io.c:972
#, c-format
msgid "Image type “%s” is not supported"
msgstr "'%s' rasm turi qoʻllanilmaydi"

#: cdk-pixbuf/cdk-pixbuf-io.c:1057
#, c-format
msgid "Couldn’t recognize the image file format for file “%s”"
msgstr "'%s' faylidagi rasm formatini aniqlab boʻlmadi"

#: cdk-pixbuf/cdk-pixbuf-io.c:1065
msgid "Unrecognized image file format"
msgstr "Nomaʼlum rasm formati"

#: cdk-pixbuf/cdk-pixbuf-io.c:1271
#, c-format
msgid "Failed to load image “%s”: %s"
msgstr "'%s' rasmi yuklanmadi: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2346 cdk-pixbuf/io-gdip-utils.c:840
#, c-format
msgid "Error writing to image file: %s"
msgstr "Rasm fayliga yozishda xatolik yuz berdi: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2388 cdk-pixbuf/cdk-pixbuf-io.c:2509
#, c-format
msgid "This build of cdk-pixbuf does not support saving the image format: %s"
msgstr ""
"Ushbu cdk-pixbuf qurilmasi rasm formatini saqlashni qo‘llab-quvvatlamaydi: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2419
msgid "Insufficient memory to save image to callback"
msgstr "Rasmni qayta qo'ng'iroq qilish uchun saqlash uchun xotira yetarli emas"

#: cdk-pixbuf/cdk-pixbuf-io.c:2432
msgid "Failed to open temporary file"
msgstr "Vaqtinchalik faylni ochib boʻlmadi"

#: cdk-pixbuf/cdk-pixbuf-io.c:2455
msgid "Failed to read from temporary file"
msgstr "Vaqtinchalik fayldan oʻqib boʻlmadi"

#: cdk-pixbuf/cdk-pixbuf-io.c:2677
#, c-format
msgid "Failed to open “%s” for writing: %s"
msgstr "'%s' faylini yozish uchun ochib boʻlmadi: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2703
#, c-format
msgid ""
"Failed to close “%s” while writing image, all data may not have been saved: "
"%s"
msgstr ""
"Rasm yozish paytida “%s” yopilmadi, barcha maʼlumotlar saqlanmagan boʻlishi "
"mumkin: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2937 cdk-pixbuf/cdk-pixbuf-io.c:2992
msgid "Insufficient memory to save image into a buffer"
msgstr "Rasmni buferga saqlash uchun xotira yetishmaydi"

#: cdk-pixbuf/cdk-pixbuf-io.c:3038
msgid "Error writing to image stream"
msgstr "Rasm oqimiga yozishda xatolik yuz berdi"

#: cdk-pixbuf/cdk-pixbuf-loader.c:426
#, c-format
msgid ""
"Internal error: Image loader module “%s” failed to complete an operation, "
"but didn’t give a reason for the failure"
msgstr ""
"Ichki xato: “%s” tasvir yuklash moduli operatsiyani yakunlay olmadi, lekin "
"xato sababini ko‘rsatmadi"

#: cdk-pixbuf/cdk-pixbuf-loader.c:468
#, c-format
msgid "Incremental loading of image type “%s” is not supported"
msgstr "'%s' rasm turi qoʻllanilmaydi"

#: cdk-pixbuf/cdk-pixbuf-simple-anim.c:166
msgid "Loop"
msgstr "Loop"

#: cdk-pixbuf/cdk-pixbuf-simple-anim.c:167
msgid "Whether the animation should loop when it reaches the end"
msgstr "Animatsiya oxiriga yetganda aylanish kerakmi"

#: cdk-pixbuf/cdk-pixdata.c:178
msgid "Image header corrupt"
msgstr "Rasm saravhasi buzuq"

#: cdk-pixbuf/cdk-pixdata.c:183
msgid "Image format unknown"
msgstr "Rasm formati nomaʼlum"

#: cdk-pixbuf/cdk-pixdata.c:188 cdk-pixbuf/cdk-pixdata.c:491
#: cdk-pixbuf/cdk-pixdata.c:501 cdk-pixbuf/cdk-pixdata.c:597
msgid "Image pixel data corrupt"
msgstr "Rasmning piksel maʼlumotlari xato"

#: cdk-pixbuf/cdk-pixdata.c:513
#, c-format
msgid "failed to allocate image buffer of %u byte"
msgid_plural "failed to allocate image buffer of %u bytes"
msgstr[0] "%u baytlik rasm buferini ajratib boʻlmadi"
msgstr[1] "%u baytlik rasm buferini ajratib boʻlmadi"

#: cdk-pixbuf/io-ani.c:239
msgid "Unexpected icon chunk in animation"
msgstr "Animatsiyadagi kutilmagan piktogramma qismi"

#: cdk-pixbuf/io-ani.c:303 cdk-pixbuf/io-ani.c:404 cdk-pixbuf/io-ani.c:430
#: cdk-pixbuf/io-ani.c:449
msgid "Malformed chunk in animation"
msgstr "Animatsiyada noto‘g‘ri shakllangan bo‘lak"

#: cdk-pixbuf/io-ani.c:311 cdk-pixbuf/io-ani.c:354 cdk-pixbuf/io-ani.c:412
#: cdk-pixbuf/io-ani.c:438 cdk-pixbuf/io-ani.c:461 cdk-pixbuf/io-ani.c:488
#: cdk-pixbuf/io-ani.c:575
msgid "Invalid header in animation"
msgstr "Animatsiyadagi sarlavha noto‘g‘ri"

#: cdk-pixbuf/io-ani.c:364 cdk-pixbuf/io-ani.c:386 cdk-pixbuf/io-ani.c:470
#: cdk-pixbuf/io-ani.c:497 cdk-pixbuf/io-ani.c:548 cdk-pixbuf/io-ani.c:624
msgid "Not enough memory to load animation"
msgstr "Animatsiyani yuklash uchun xotira yetishmaydi"

#: cdk-pixbuf/io-ani.c:646
msgid "ANI image was truncated or incomplete."
msgstr "ANI tasviri kesilgan yoki toʻliq boʻlmagan."

#: cdk-pixbuf/io-ani.c:687
msgctxt "image format"
msgid "Windows animated cursor"
msgstr "Windows animatsion kursor"

#: cdk-pixbuf/io-bmp.c:234 cdk-pixbuf/io-bmp.c:275 cdk-pixbuf/io-bmp.c:385
#: cdk-pixbuf/io-bmp.c:412 cdk-pixbuf/io-bmp.c:437 cdk-pixbuf/io-bmp.c:472
#: cdk-pixbuf/io-bmp.c:494 cdk-pixbuf/io-bmp.c:572
msgid "BMP image has bogus header data"
msgstr "BMP tasvirida soxta sarlavha ma'lumotlari mavjud"

#: cdk-pixbuf/io-bmp.c:245 cdk-pixbuf/io-bmp.c:507
msgid "Not enough memory to load bitmap image"
msgstr "Bitmap tasvirni yuklash uchun xotira yetarli emas"

#: cdk-pixbuf/io-bmp.c:339
msgid "BMP image has unsupported header size"
msgstr "BMP tasviri qoʻllab-quvvatlanmaydigan sarlavha hajmiga ega"

#: cdk-pixbuf/io-bmp.c:348
msgid "BMP image has unsupported depth"
msgstr "BMP tasviri qoʻllab-quvvatlanmaydigan chuqurlikka ega"

#: cdk-pixbuf/io-bmp.c:367
msgid "BMP image has oversize palette"
msgstr "BMP tasviri katta hajmli palitraga ega"

#: cdk-pixbuf/io-bmp.c:399
msgid "Topdown BMP images cannot be compressed"
msgstr "Yuqoridan pastga BMP tasvirlarni siqib bo'lmaydi"

#: cdk-pixbuf/io-bmp.c:424
msgid "BMP image width too large"
msgstr "BMP tasvir kengligi juda katta"

#: cdk-pixbuf/io-bmp.c:814 cdk-pixbuf/io-png.c:587 cdk-pixbuf/io-pnm.c:722
#: cdk-pixbuf/io-pnm.c:879
msgid "Premature end-of-file encountered"
msgstr "Faylning muddatidan oldin tugashiga duch keldi"

#: cdk-pixbuf/io-bmp.c:1340
msgid "Error while decoding colormap"
msgstr "Rang xaritasini dekodlashda xatolik yuz berdi"

#: cdk-pixbuf/io-bmp.c:1403 cdk-pixbuf/io-bmp.c:1415
msgid "Image is too wide for BMP format."
msgstr "Rasm BMP formati uchun juda keng."

#: cdk-pixbuf/io-bmp.c:1448
msgid "Couldn’t allocate memory for saving BMP file"
msgstr "Meta-faylni yuklab boʻlmadi"

#: cdk-pixbuf/io-bmp.c:1489
msgid "Couldn’t write to BMP file"
msgstr "BMP fayliga yozib boʻlmadi"

#: cdk-pixbuf/io-bmp.c:1542 cdk-pixbuf/io-gdip-bmp.c:83
msgctxt "image format"
msgid "BMP"
msgstr "BMP"

#: cdk-pixbuf/io-gdip-emf.c:61
msgctxt "image format"
msgid "EMF"
msgstr "EMF"

#: cdk-pixbuf/io-gdip-gif.c:81 cdk-pixbuf/io-gif.c:1039
msgctxt "image format"
msgid "GIF"
msgstr "GIF"

#: cdk-pixbuf/io-gdip-ico.c:60 cdk-pixbuf/io-ico.c:1418
msgctxt "image format"
msgid "Windows icon"
msgstr "Windows belgisi"

#: cdk-pixbuf/io-gdip-jpeg.c:54 cdk-pixbuf/io-jpeg.c:1409
#, c-format
msgid ""
"JPEG quality must be a value between 0 and 100; value “%s” could not be "
"parsed."
msgstr ""
"JPEG sifati 0 dan 100 gacha bo'lgan qiymat bo'lishi kerak; “%s” qiymatini "
"tahlil qilib bo‘lmadi."

#: cdk-pixbuf/io-gdip-jpeg.c:69 cdk-pixbuf/io-jpeg.c:1425
#, c-format
msgid ""
"JPEG quality must be a value between 0 and 100; value “%d” is not allowed."
msgstr ""
"JPEG sifati 0 dan 100 gacha bo'lgan qiymat bo'lishi kerak; “%d” qiymatiga "
"ruxsat berilmagan."

#: cdk-pixbuf/io-gdip-jpeg.c:147 cdk-pixbuf/io-jpeg.c:1710
msgctxt "image format"
msgid "JPEG"
msgstr "JPEG"

#: cdk-pixbuf/io-gdip-tiff.c:83 cdk-pixbuf/io-tiff.c:1087
msgctxt "image format"
msgid "TIFF"
msgstr "TIFF"

#: cdk-pixbuf/io-gdip-utils.c:155
#, c-format
msgid "Could not allocate memory: %s"
msgstr "Xotira ajratilmadi: %s"

#: cdk-pixbuf/io-gdip-utils.c:180 cdk-pixbuf/io-gdip-utils.c:294
#: cdk-pixbuf/io-gdip-utils.c:334
#, c-format
msgid "Could not create stream: %s"
msgstr "Quyidagi oqimni yaratib boʻlmadi: %s"

#: cdk-pixbuf/io-gdip-utils.c:194
#, c-format
msgid "Could not seek stream: %s"
msgstr "Translatsiyani qidirib bo‘lmadi: %s"

#: cdk-pixbuf/io-gdip-utils.c:206
#, c-format
msgid "Could not read from stream: %s"
msgstr "Quyidagi oqimdan oʻqib boʻlmadi: %s"

#: cdk-pixbuf/io-gdip-utils.c:620
msgid "Couldn’t load bitmap"
msgstr "Meta-faylni yuklab boʻlmadi"

#: cdk-pixbuf/io-gdip-utils.c:776
msgid "Couldn’t load metafile"
msgstr "Meta-faylni yuklab boʻlmadi"

#: cdk-pixbuf/io-gdip-utils.c:881
msgid "Unsupported image format for GDI+"
msgstr "GDI+ uchun qoʻllanilmaydigan rasm formati"

#: cdk-pixbuf/io-gdip-utils.c:888
msgid "Couldn’t save"
msgstr "Saqlab boʻlmadi"

#: cdk-pixbuf/io-gdip-wmf.c:60
msgctxt "image format"
msgid "WMF"
msgstr "WMF"

#: cdk-pixbuf/io-gif.c:160
#, c-format
msgid "Failure reading GIF: %s"
msgstr "GIF o‘qilmadi: %s"

#: cdk-pixbuf/io-gif.c:383 cdk-pixbuf/io-gif.c:850 cdk-pixbuf/io-gif.c:903
#: cdk-pixbuf/io-gif.c:976
msgid "Not enough memory to load GIF file"
msgstr "GIF faylini yuklash uchun xotira yetarli emas"

#: cdk-pixbuf/io-gif.c:509
msgid "GIF image is corrupt (incorrect LZW compression)"
msgstr "GIF tasviri buzilgan (noto'g'ri LZW siqish)"

#: cdk-pixbuf/io-gif.c:545
msgid "File does not appear to be a GIF file"
msgstr "Fayl GIF fayli emas"

#: cdk-pixbuf/io-gif.c:560
#, c-format
msgid "Version %s of the GIF file format is not supported"
msgstr "GIF fayl formatining %s-versiyasi qo‘llab-quvvatlanmaydi"

#: cdk-pixbuf/io-gif.c:589
msgid "Resulting GIF image has zero size"
msgstr "Natijadagi GIF tasviri nolga teng"

#: cdk-pixbuf/io-gif.c:659
msgid ""
"GIF image has no global colormap, and a frame inside it has no local "
"colormap."
msgstr ""
"GIF rasmida global rang xaritasi yo'q va uning ichidagi ramkada mahalliy "
"rang xaritasi yo'q."

#: cdk-pixbuf/io-gif.c:863 cdk-pixbuf/io-gif.c:988
msgid "GIF file was missing some data (perhaps it was truncated somehow?)"
msgstr ""
"GIF faylida ba'zi ma'lumotlar yo'q edi (ehtimol u qandaydir tarzda "
"kesilganmi?)"

#: cdk-pixbuf/io-gif.c:922
msgid "GIF image was truncated or incomplete."
msgstr "GIF tasviri kesilgan yoki toʻliq boʻlmagan."

#: cdk-pixbuf/io-gif.c:929
msgid "Not all frames of the GIF image were loaded."
msgstr "GIF tasvirining barcha ramkalari yuklanmagan."

#: cdk-pixbuf/io-icns.c:363
#, c-format
msgid "Error reading ICNS image: %s"
msgstr "ICNS rasmini oʻqishda xatolik yuz berdi: %s"

#: cdk-pixbuf/io-icns.c:380 cdk-pixbuf/io-icns.c:461
msgid "Could not decode ICNS file"
msgstr "ICNS faylini dekodlab boʻlmadi"

#: cdk-pixbuf/io-icns.c:517
msgctxt "image format"
msgid "MacOS X icon"
msgstr "MacOS X belgisi"

#: cdk-pixbuf/io-ico.c:238 cdk-pixbuf/io-ico.c:252 cdk-pixbuf/io-ico.c:342
#: cdk-pixbuf/io-ico.c:426 cdk-pixbuf/io-ico.c:451
#, c-format
msgid "Invalid header in icon (%s)"
msgstr "Belgidagi sarlavha noto‘g‘ri (%s)"

#: cdk-pixbuf/io-ico.c:268 cdk-pixbuf/io-ico.c:355 cdk-pixbuf/io-ico.c:461
#: cdk-pixbuf/io-ico.c:504 cdk-pixbuf/io-ico.c:532
msgid "Not enough memory to load icon"
msgstr "Belgini yuklash uchun xotira yetarli emas"

#: cdk-pixbuf/io-ico.c:386
msgid "Invalid header in icon"
msgstr "Belgidagi sarlavha noto‘g‘ri"

#: cdk-pixbuf/io-ico.c:387
msgid "Compressed icons are not supported"
msgstr "Siqilgan piktogrammalar qo'llab-quvvatlanmaydi"

#: cdk-pixbuf/io-ico.c:489
msgid "Unsupported icon type"
msgstr "Qo'llab-quvvatlanmaydigan belgi turi"

#: cdk-pixbuf/io-ico.c:583
msgid "Not enough memory to load ICO file"
msgstr "ICO faylini yuklash uchun xotira yetarli emas"

#: cdk-pixbuf/io-ico.c:629
msgid "ICO image was truncated or incomplete."
msgstr "ICO tasviri kesilgan yoki toʻliq boʻlmagan."

#: cdk-pixbuf/io-ico.c:1070
msgid "Image too large to be saved as ICO"
msgstr "Rasm ICO sifatida saqlash uchun juda katta"

#: cdk-pixbuf/io-ico.c:1081
msgid "Cursor hotspot outside image"
msgstr "Kursorning kirish nuqtasi tasvir tashqarisi"

#: cdk-pixbuf/io-ico.c:1104
#, c-format
msgid "Unsupported depth for ICO file: %d"
msgstr "ICO fayli uchun qoʻllab-quvvatlanmaydigan chuqurlik: %d"

#: cdk-pixbuf/io-jpeg.c:131
#, c-format
msgid "Error interpreting JPEG image file (%s)"
msgstr "JPEG rasm faylini talqin qilishda xatolik yuz berdi (%s)"

#: cdk-pixbuf/io-jpeg.c:647
msgid ""
"Insufficient memory to load image, try exiting some applications to free "
"memory"
msgstr ""
"Rasmni yuklash uchun xotira yetarli emas, xotirani boʻshatish uchun baʼzi "
"ilovalardan chiqib koʻring"

#: cdk-pixbuf/io-jpeg.c:720 cdk-pixbuf/io-jpeg.c:970
#, c-format
msgid "Unsupported JPEG color space (%s)"
msgstr "Qo'llab-quvvatlanmaydigan JPEG rang maydoni (%s)"

#: cdk-pixbuf/io-jpeg.c:845 cdk-pixbuf/io-jpeg.c:1169 cdk-pixbuf/io-jpeg.c:1516
#: cdk-pixbuf/io-jpeg.c:1526
msgid "Couldn’t allocate memory for loading JPEG file"
msgstr "Meta-faylni yuklab boʻlmadi"

#: cdk-pixbuf/io-jpeg.c:1127
msgid "Transformed JPEG has zero width or height."
msgstr "O'zgartirilgan JPEG kengligi yoki balandligi nolga teng."

#: cdk-pixbuf/io-jpeg.c:1153
#, c-format
msgid "Unsupported number of color components (%d)"
msgstr "Rang komponentlarining qoʻllab-quvvatlanmaydigan soni (%d)"

#: cdk-pixbuf/io-jpeg.c:1446
#, c-format
msgid ""
"JPEG x-dpi must be a value between 1 and 65535; value “%s” is not allowed."
msgstr ""
"JPEG x-dpi qiymati 1 va 65535 oralig'ida bo'lishi kerak; “%s” qiymatiga "
"ruxsat berilmagan."

#: cdk-pixbuf/io-jpeg.c:1467
#, c-format
msgid ""
"JPEG y-dpi must be a value between 1 and 65535; value “%s” is not allowed."
msgstr ""
"JPEG y-dpi 1 dan 65535 gacha bo'lgan qiymat bo'lishi kerak; “%s” qiymatiga "
"ruxsat berilmagan."

#: cdk-pixbuf/io-jpeg.c:1481
#, c-format
msgid "Color profile has invalid length “%u”."
msgstr "Rang profilining uzunligi “%u” yaroqsiz."

#: cdk-pixbuf/io-png.c:64
msgid "Bits per channel of PNG image is invalid."
msgstr "PNG tasvirining har bir kanali uchun bitlar yaroqsiz."

#: cdk-pixbuf/io-png.c:145 cdk-pixbuf/io-png.c:730
msgid "Transformed PNG has zero width or height."
msgstr "O'zgartirilgan PNG kengligi yoki balandligi nolga teng."

#: cdk-pixbuf/io-png.c:153
msgid "Bits per channel of transformed PNG is not 8."
msgstr "O'zgartirilgan PNG kanali uchun bitlar 8 emas."

#: cdk-pixbuf/io-png.c:162
msgid "Transformed PNG not RGB or RGBA."
msgstr "RGB yoki RGBA emas, o'zgartirilgan PNG."

#: cdk-pixbuf/io-png.c:171
msgid "Transformed PNG has unsupported number of channels, must be 3 or 4."
msgstr ""
"Oʻzgartirilgan PNG formatida qoʻllab-quvvatlanmaydigan kanallar soni 3 yoki "
"4 ta boʻlishi kerak."

#: cdk-pixbuf/io-png.c:193
