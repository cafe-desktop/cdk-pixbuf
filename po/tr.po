# cdk-pixbuf/io-gif.c:1407
#: cdk-pixbuf/io-ani.c:629
msgid "ANI image was truncated or incomplete."
msgstr "ANI resmi ya kırpılmış ya da tamamlanmamış."

#: cdk-pixbuf/io-ani.c:670
msgctxt "image format"
msgid "Windows animated cursor"
msgstr "Pencere canlandırmalı imleç"

# cdk-pixbuf/io-bmp.c:278 cdk-pixbuf/io-bmp.c:300
