#: cdk-pixbuf/io-gif.c:543
msgid "File does not appear to be a GIF file"
msgstr "Dosya bir GIF dosyası gibi görünmüyor"

# cdk-pixbuf/io-gif.c:1052
#: cdk-pixbuf/io-gif.c:558
#, c-format
msgid "Version %s of the GIF file format is not supported"
msgstr "%s sürümü GIF dosya biçimi desteklenmiyor"

#: cdk-pixbuf/io-gif.c:587
msgid "Resulting GIF image has zero size"
msgstr "Oluşan GIF resim boyutu sıfır"

# cdk-pixbuf/io-gif.c:1178
#: cdk-pixbuf/io-gif.c:657
msgid ""
"GIF image has no global colormap, and a frame inside it has no local "
"colormap."
msgstr ""
"GIF resmi genel renk eşlemi içermiyor ve bir çerçeve içi yerel renk eşlemi "
"de yok."

# cdk-pixbuf/io-gif.c:460 cdk-pixbuf/io-gif.c:1352 cdk-pixbuf/io-gif.c:1511
#: cdk-pixbuf/io-gif.c:861 cdk-pixbuf/io-gif.c:986
msgid "GIF file was missing some data (perhaps it was truncated somehow?)"
msgstr "GIF dosyasında veri eksik (dosya kırpılmış olabilir mi?)"

# cdk-pixbuf/io-gif.c:1407
#: cdk-pixbuf/io-gif.c:920
msgid "GIF image was truncated or incomplete."
msgstr "GIF resmi ya kırpılmış ya da tamamlanmamış."

#: cdk-pixbuf/io-gif.c:927
msgid "Not all frames of the GIF image were loaded."
msgstr "GIF resminin tüm kareleri yüklenmedi."

# cdk-pixbuf/io-png.c:610
