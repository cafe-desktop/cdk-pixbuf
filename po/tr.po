msgstr "GIF okunamadı: %s"

# cdk-pixbuf/io-gif.c:746 cdk-pixbuf/io-gif.c:1340 cdk-pixbuf/io-gif.c:1385
# cdk-pixbuf/io-gif.c:1499
#: cdk-pixbuf/io-gif.c:381 cdk-pixbuf/io-gif.c:848 cdk-pixbuf/io-gif.c:901
#: cdk-pixbuf/io-gif.c:974
msgid "Not enough memory to load GIF file"
msgstr "GIF dosyasını yüklemek için yetersiz bellek"

