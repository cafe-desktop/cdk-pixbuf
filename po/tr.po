# cdk-pixbuf/cdk-pixbuf-animation.c:144 cdk-pixbuf/cdk-pixbuf-io.c:516
#: cdk-pixbuf/cdk-pixbuf-animation.c:185 cdk-pixbuf/cdk-pixbuf-io.c:1129
#: cdk-pixbuf/cdk-pixbuf-io.c:1402
#, c-format
msgid "Failed to open file “%s”: %s"
msgstr "“%s” dosyası açılamadı: %s"

# cdk-pixbuf/cdk-pixbuf-animation.c:155 cdk-pixbuf/cdk-pixbuf-io.c:526
#: cdk-pixbuf/cdk-pixbuf-animation.c:198 cdk-pixbuf/cdk-pixbuf-io.c:990
#, c-format
msgid "Image file “%s” contains no data"
msgstr "Resim dosyası “%s” hiç bilgi içermiyor"

# cdk-pixbuf/cdk-pixbuf-animation.c:233
#: cdk-pixbuf/cdk-pixbuf-animation.c:236
#, c-format
msgid ""
"Failed to load animation “%s”: reason not known, probably a corrupt "
"animation file"
msgstr ""
"“%s” canlandıması yüklenemedi: neden bilinmiyor, canlandırma dosyası "
"bozulmuş olabilir"

# cdk-pixbuf/cdk-pixbuf-animation.c:205 cdk-pixbuf/cdk-pixbuf-io.c:571
#: cdk-pixbuf/cdk-pixbuf-animation.c:304 cdk-pixbuf/cdk-pixbuf-io.c:1165
#: cdk-pixbuf/cdk-pixbuf-io.c:1454
#, c-format
msgid ""
"Failed to load image “%s”: reason not known, probably a corrupt image file"
msgstr "“%s” resmi yüklenemedi: neden bilinmiyor, dosya bozulmuş olabilir"

#: cdk-pixbuf/cdk-pixbuf.c:248
msgid "Number of Channels"
msgstr "Kanal Sayısı"

# cdk-pixbuf/io-xpm.c:1265
#: cdk-pixbuf/cdk-pixbuf.c:249
msgid "The number of samples per pixel"
msgstr "Piksel başına örnek sayısı"

#: cdk-pixbuf/cdk-pixbuf.c:264
msgid "Colorspace"
msgstr "Renk uzayı"

#: cdk-pixbuf/cdk-pixbuf.c:265
msgid "The colorspace in which the samples are interpreted"
msgstr "İçinde örneklerin yorumlandığı renk uzayı"

#: cdk-pixbuf/cdk-pixbuf.c:277
msgid "Has Alpha"
msgstr "Alfa Var"

#: cdk-pixbuf/cdk-pixbuf.c:278
msgid "Whether the pixbuf has an alpha channel"
msgstr "pixbuf'un bir alfa kanalına sahip olup olmaması"

#: cdk-pixbuf/cdk-pixbuf.c:291
msgid "Bits per Sample"
msgstr "Örnek Başına Bit"

#: cdk-pixbuf/cdk-pixbuf.c:292
msgid "The number of bits per sample"
msgstr "Örnek başına düşen bit sayısı"

#: cdk-pixbuf/cdk-pixbuf.c:305
msgid "Width"
msgstr "Genişlik"

#: cdk-pixbuf/cdk-pixbuf.c:306
msgid "The number of columns of the pixbuf"
msgstr "pixbuf'un sütun sayısı"

#: cdk-pixbuf/cdk-pixbuf.c:319
msgid "Height"
msgstr "Yükseklik"

#: cdk-pixbuf/cdk-pixbuf.c:320
msgid "The number of rows of the pixbuf"
msgstr "pixbuf'un satır sayısı"

#: cdk-pixbuf/cdk-pixbuf.c:337
msgid "Rowstride"
msgstr "Satır adımlaması"

#: cdk-pixbuf/cdk-pixbuf.c:338
msgid ""
"The number of bytes between the start of a row and the start of the next row"
msgstr ""
"Bir satırın başlangıcı ile sonraki satırın başlangıcı arasındaki bayt sayısı"

#: cdk-pixbuf/cdk-pixbuf.c:351
msgid "Pixels"
msgstr "Piksel"

#: cdk-pixbuf/cdk-pixbuf.c:352
msgid "A pointer to the pixel data of the pixbuf"
msgstr "Pixbuf'un piksel verisine bir işaretçi"

#: cdk-pixbuf/cdk-pixbuf.c:366
msgid "Pixel Bytes"
msgstr "Piksel Bayt"

#: cdk-pixbuf/cdk-pixbuf.c:367
msgid "Readonly pixel data"
msgstr "Salt okunur piksel verisi"

# cdk-pixbuf/cdk-pixbuf-io.c:295
#: cdk-pixbuf/cdk-pixbuf-io.c:807
#, c-format
msgid "Unable to load image-loading module: %s: %s"
msgstr "Resim yükleme modülü bulunamadı: %s: %s"

# cdk-pixbuf/cdk-pixbuf-io.c:314
#: cdk-pixbuf/cdk-pixbuf-io.c:824
#, c-format
msgid ""
"Image-loading module %s does not export the proper interface; perhaps it’s "
"from a different cdk-pixbuf version?"
msgstr ""
"%s resim yükleme modülü doğru arayüze gönderilmemiş, farklı bir cdk-pixbuf "
"sürümünden olabilir mi?"

# cdk-pixbuf/cdk-pixbuf-io.c:425 cdk-pixbuf/cdk-pixbuf-io.c:451
#: cdk-pixbuf/cdk-pixbuf-io.c:834 cdk-pixbuf/cdk-pixbuf-io.c:877
#, c-format
msgid "Image type “%s” is not supported"
msgstr "“%s” resim türü desteklenmiyor"

# cdk-pixbuf/cdk-pixbuf-io.c:473
#: cdk-pixbuf/cdk-pixbuf-io.c:962
#, c-format
msgid "Couldn’t recognize the image file format for file “%s”"
msgstr "“%s” dosyasındaki resmin biçimi anlaşılamadı"

# cdk-pixbuf/cdk-pixbuf-io.c:479
#: cdk-pixbuf/cdk-pixbuf-io.c:970
msgid "Unrecognized image file format"
msgstr "Bilinmeyen resim dosyası biçimi"

# cdk-pixbuf/cdk-pixbuf-io.c:582
#: cdk-pixbuf/cdk-pixbuf-io.c:1176
#, c-format
msgid "Failed to load image “%s”: %s"
msgstr "“%s” resmi yüklenemedi: %s"

# cdk-pixbuf/io-jpeg.c:125
#: cdk-pixbuf/cdk-pixbuf-io.c:2244 cdk-pixbuf/io-gdip-utils.c:840
#, c-format
msgid "Error writing to image file: %s"
msgstr "JPEG resim dosyası işlenirken hata: %s"

# cdk-pixbuf/cdk-pixbuf-io.c:687
#: cdk-pixbuf/cdk-pixbuf-io.c:2286 cdk-pixbuf/cdk-pixbuf-io.c:2407
#, c-format
msgid "This build of cdk-pixbuf does not support saving the image format: %s"
msgstr "cdk-pixbuf'un bu inşası resim biçimi kaydını desteklemiyor: %s"

# cdk-pixbuf/io-xbm.c:295
#: cdk-pixbuf/cdk-pixbuf-io.c:2317
msgid "Insufficient memory to save image to callback"
msgstr "Geri çağırım için resim kaydedilirken yetersiz bellek"

# cdk-pixbuf/io-tiff.c:264
#: cdk-pixbuf/cdk-pixbuf-io.c:2330
msgid "Failed to open temporary file"
msgstr "Geçici dosya açılamadı"

# cdk-pixbuf/io-xbm.c:429
#: cdk-pixbuf/cdk-pixbuf-io.c:2353
msgid "Failed to read from temporary file"
msgstr "Geçici dosya okumak için açılamadı"

# cdk-pixbuf/cdk-pixbuf-io.c:790
#: cdk-pixbuf/cdk-pixbuf-io.c:2575
#, c-format
msgid "Failed to open “%s” for writing: %s"
msgstr "“%s” dosyası yazmak için açılamadı: %s"

# cdk-pixbuf/cdk-pixbuf-io.c:811
#: cdk-pixbuf/cdk-pixbuf-io.c:2601
#, c-format
msgid ""
"Failed to close “%s” while writing image, all data may not have been saved: "
"%s"
msgstr ""
"Resim yazılırken “%s” kapatılamadı, tüm veri kaydedilememiş olabilir: %s"

# cdk-pixbuf/io-xbm.c:295
#: cdk-pixbuf/cdk-pixbuf-io.c:2835 cdk-pixbuf/cdk-pixbuf-io.c:2890
msgid "Insufficient memory to save image into a buffer"
msgstr "Resmi tampona kaydetmek için yetersiz bellek"

# cdk-pixbuf/io-jpeg.c:125
#: cdk-pixbuf/cdk-pixbuf-io.c:2936
msgid "Error writing to image stream"
msgstr "Resim akışına yazılırken hata"

# cdk-pixbuf/cdk-pixbuf-loader.c:275 cdk-pixbuf/cdk-pixbuf-loader.c:376
#: cdk-pixbuf/cdk-pixbuf-loader.c:416
#, c-format
msgid ""
"Internal error: Image loader module “%s” failed to complete an operation, "
"but didn’t give a reason for the failure"
msgstr ""
"Dahili hata: “%s” resim yükleme modülü işlemi tamamlayamadı, ama "
"başarısızlık nedeni de vermedi"

# cdk-pixbuf/cdk-pixbuf-loader.c:252
#: cdk-pixbuf/cdk-pixbuf-loader.c:458
#, c-format
msgid "Incremental loading of image type “%s” is not supported"
msgstr "Resim türü “%s” için arttırımlı yükleme desteklenmiyor"

#: cdk-pixbuf/cdk-pixbuf-simple-anim.c:162
msgid "Loop"
msgstr "Döngü"

#: cdk-pixbuf/cdk-pixbuf-simple-anim.c:163
msgid "Whether the animation should loop when it reaches the end"
msgstr "Canlandırmanın bittikten sonra tekrar başa dönüp dönmeyeceği"

# cdk-pixbuf/cdk-pixdata.c:145
#: cdk-pixbuf/cdk-pixdata.c:178
msgid "Image header corrupt"
msgstr "Resim başlığı bozuk"

# cdk-pixbuf/cdk-pixdata.c:150
#: cdk-pixbuf/cdk-pixdata.c:183
msgid "Image format unknown"
msgstr "Resim biçimi bilinmiyor"

