#: cdk-pixbuf/io-bmp.c:1328
msgid "Couldn't allocate memory for saving BMP file"
msgstr "تعذّر تحصيص ذاكرة لحفظ ملف BMP"

#: cdk-pixbuf/io-bmp.c:1369
msgid "Couldn't write to BMP file"
msgstr "تعذّر الكتابة في ملف BMP "

#: cdk-pixbuf/io-bmp.c:1422 cdk-pixbuf/io-gdip-bmp.c:82
msgid "The BMP image format"
msgstr "صيغة صور BMP"

#: cdk-pixbuf/io-gdip-emf.c:59
msgid "The EMF image format"
msgstr "صيغة صور EMF"

#: cdk-pixbuf/io-gdip-gif.c:80 cdk-pixbuf/io-gif.c:1699
