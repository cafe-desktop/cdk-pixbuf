#: cdk-pixbuf/cdk-pixbuf-animation.c:185 cdk-pixbuf/cdk-pixbuf-io.c:1130
#: cdk-pixbuf/cdk-pixbuf-io.c:1403
#, c-format
msgid "Failed to open file “%s”: %s"
msgstr "Неуспешно отваряне на файла „%s“: %s"

#: cdk-pixbuf/cdk-pixbuf-animation.c:198 cdk-pixbuf/cdk-pixbuf-io.c:991
#, c-format
msgid "Image file “%s” contains no data"
msgstr "Графичният файл „%s“ не съдържа данни"

#: cdk-pixbuf/cdk-pixbuf-animation.c:236
#, c-format
msgid ""
"Failed to load animation “%s”: reason not known, probably a corrupt "
"animation file"
msgstr ""
"Неуспешно зареждане на анимацията „%s“: неизвестна причина, вероятно "
"повреден файл"

#: cdk-pixbuf/cdk-pixbuf-animation.c:304 cdk-pixbuf/cdk-pixbuf-io.c:1166
#: cdk-pixbuf/cdk-pixbuf-io.c:1455
#, c-format
msgid ""
"Failed to load image “%s”: reason not known, probably a corrupt image file"
msgstr ""
"Неуспешно зареждане на изображението „%s“: неизвестна причина, вероятно "
"повреден файл"

#: cdk-pixbuf/cdk-pixbuf.c:248
msgid "Number of Channels"
msgstr "Брой канали"

#: cdk-pixbuf/cdk-pixbuf.c:249
msgid "The number of samples per pixel"
msgstr "Брой отчети на пиксел"

#: cdk-pixbuf/cdk-pixbuf.c:264
msgid "Colorspace"
msgstr "Цветово пространство"

#: cdk-pixbuf/cdk-pixbuf.c:265
msgid "The colorspace in which the samples are interpreted"
msgstr "Цветовото пространство, за което са отчетите"

#: cdk-pixbuf/cdk-pixbuf.c:277
msgid "Has Alpha"
msgstr "С канал за прозрачност"

#: cdk-pixbuf/cdk-pixbuf.c:278
msgid "Whether the pixbuf has an alpha channel"
msgstr "Дали буферът за пиксели има канал за прозрачност"

#: cdk-pixbuf/cdk-pixbuf.c:291
msgid "Bits per Sample"
msgstr "Битове на отчет"

#: cdk-pixbuf/cdk-pixbuf.c:292
msgid "The number of bits per sample"
msgstr "Брой битове за всеки отчет"

#: cdk-pixbuf/cdk-pixbuf.c:305
msgid "Width"
msgstr "Широчина"

#: cdk-pixbuf/cdk-pixbuf.c:306
msgid "The number of columns of the pixbuf"
msgstr "Брой колони за буфера за пиксели"

#: cdk-pixbuf/cdk-pixbuf.c:319
msgid "Height"
msgstr "Височина"

#: cdk-pixbuf/cdk-pixbuf.c:320
msgid "The number of rows of the pixbuf"
msgstr "Брой редове за буфера за пиксели"

#: cdk-pixbuf/cdk-pixbuf.c:337
msgid "Rowstride"
msgstr "Дължина на реда"

#: cdk-pixbuf/cdk-pixbuf.c:338
msgid ""
"The number of bytes between the start of a row and the start of the next row"
msgstr "Броят байтове между началото на два последователни реда"

#: cdk-pixbuf/cdk-pixbuf.c:351
msgid "Pixels"
msgstr "Пиксели"

#: cdk-pixbuf/cdk-pixbuf.c:352
msgid "A pointer to the pixel data of the pixbuf"
msgstr "Указател към данните за пикселите на буфера"

#: cdk-pixbuf/cdk-pixbuf.c:366
msgid "Pixel Bytes"
msgstr "Байтове на пикселите"

#: cdk-pixbuf/cdk-pixbuf.c:367
msgid "Readonly pixel data"
msgstr "Данни за пикселите само за четене"

#: cdk-pixbuf/cdk-pixbuf-io.c:808
#, c-format
msgid "Unable to load image-loading module: %s: %s"
msgstr "Модулът за зареждане на изображения „%s“ не може да бъде зареден: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:825
#, c-format
msgid ""
"Image-loading module %s does not export the proper interface; perhaps it’s "
"from a different cdk-pixbuf version?"
msgstr ""
"Модулът за зареждане на изображения „%s“ не поддържа правилния интерфейс: "
"вероятно е от различна версия на cdk-pixbuf."

#: cdk-pixbuf/cdk-pixbuf-io.c:835 cdk-pixbuf/cdk-pixbuf-io.c:878
#, c-format
msgid "Image type “%s” is not supported"
msgstr "Изображения от вид „%s“ не се поддържат"

#: cdk-pixbuf/cdk-pixbuf-io.c:963
#, c-format
msgid "Couldn’t recognize the image file format for file “%s”"
msgstr "Форматът на графичния файл „%s“ не може да бъде разпознат"

#: cdk-pixbuf/cdk-pixbuf-io.c:971
msgid "Unrecognized image file format"
msgstr "Неразпознат графичен формат"

#: cdk-pixbuf/cdk-pixbuf-io.c:1177
#, c-format
msgid "Failed to load image “%s”: %s"
msgstr "Неуспешно зареждане на изображението „%s“: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2245 cdk-pixbuf/io-gdip-utils.c:840
#, c-format
msgid "Error writing to image file: %s"
msgstr "Грешка при запазването на изображението: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2287 cdk-pixbuf/cdk-pixbuf-io.c:2408
#, c-format
msgid "This build of cdk-pixbuf does not support saving the image format: %s"
msgstr ""
"Този компилат на „cdk-pixbuf“ не поддържа запазване в графичния формат „%s“"

#: cdk-pixbuf/cdk-pixbuf-io.c:2318
msgid "Insufficient memory to save image to callback"
msgstr "Недостатъчно памет, за да се запази изображението към функцията"

#: cdk-pixbuf/cdk-pixbuf-io.c:2331
msgid "Failed to open temporary file"
msgstr "Неуспешно отваряне на временния файл"

#: cdk-pixbuf/cdk-pixbuf-io.c:2354
msgid "Failed to read from temporary file"
msgstr "Неуспешно четене на временния файл"

#: cdk-pixbuf/cdk-pixbuf-io.c:2576
#, c-format
msgid "Failed to open “%s” for writing: %s"
msgstr "Неуспешно отваряне на „%s“ за запис: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2602
#, c-format
msgid ""
"Failed to close “%s” while writing image, all data may not have been saved: "
"%s"
msgstr ""
"Неуспешно затваряне на „%s“ по време на запис на изображение, възможно е да "
"не са запазени всички данни: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2836 cdk-pixbuf/cdk-pixbuf-io.c:2891
msgid "Insufficient memory to save image into a buffer"
msgstr "Недостатъчно памет за запазването на изображението в буфер"

#: cdk-pixbuf/cdk-pixbuf-io.c:2937
msgid "Error writing to image stream"
msgstr "Грешка при запазването към поток с изображение"

#: cdk-pixbuf/cdk-pixbuf-loader.c:416
#, c-format
msgid ""
"Internal error: Image loader module “%s” failed to complete an operation, "
"but didn’t give a reason for the failure"
msgstr ""
"Вътрешна грешка: модулът за зареждане на изображение „%s“ не успя да завърши "
"някое действие, но не ука̀за причина за това"

#: cdk-pixbuf/cdk-pixbuf-loader.c:458
#, c-format
msgid "Incremental loading of image type “%s” is not supported"
msgstr "Не се поддържа постепенно зареждане на изображение от вида „%s“"

#: cdk-pixbuf/cdk-pixbuf-simple-anim.c:162
msgid "Loop"
msgstr "Повтаряне"

#: cdk-pixbuf/cdk-pixbuf-simple-anim.c:163
msgid "Whether the animation should loop when it reaches the end"
msgstr "Дали анимацията да се повтаря непрекъснато"

#: cdk-pixbuf/cdk-pixdata.c:178
msgid "Image header corrupt"
msgstr "Заглавната част на изображението е повредена"

#: cdk-pixbuf/cdk-pixdata.c:183
msgid "Image format unknown"
msgstr "Неизвестен формат на изображението"

#: cdk-pixbuf/cdk-pixdata.c:188 cdk-pixbuf/cdk-pixdata.c:491
#: cdk-pixbuf/cdk-pixdata.c:501 cdk-pixbuf/cdk-pixdata.c:597
msgid "Image pixel data corrupt"
msgstr "Повредени данни за пикселите на изображението"

#: cdk-pixbuf/cdk-pixdata.c:513
#, c-format
msgid "failed to allocate image buffer of %u byte"
msgid_plural "failed to allocate image buffer of %u bytes"
msgstr[0] "неуспешно заделяне на буфер от %u байт за изображение"
msgstr[1] "неуспешно заделяне на буфер от %u байта за изображение"

#: cdk-pixbuf/io-ani.c:239
msgid "Unexpected icon chunk in animation"
msgstr "Неочакван откъс за икона в анимация"

#: cdk-pixbuf/io-ani.c:337 cdk-pixbuf/io-ani.c:395 cdk-pixbuf/io-ani.c:421
#: cdk-pixbuf/io-ani.c:444 cdk-pixbuf/io-ani.c:471 cdk-pixbuf/io-ani.c:558
msgid "Invalid header in animation"
msgstr "Грешна заглавна част в анимацията"

#: cdk-pixbuf/io-ani.c:347 cdk-pixbuf/io-ani.c:369 cdk-pixbuf/io-ani.c:453
#: cdk-pixbuf/io-ani.c:480 cdk-pixbuf/io-ani.c:531 cdk-pixbuf/io-ani.c:607
msgid "Not enough memory to load animation"
msgstr "Недостатъчно памет за зареждане на анимацията"

#: cdk-pixbuf/io-ani.c:387 cdk-pixbuf/io-ani.c:413 cdk-pixbuf/io-ani.c:432
msgid "Malformed chunk in animation"
msgstr "Грешно форматиран откъс в анимацията"

#: cdk-pixbuf/io-ani.c:629
msgid "ANI image was truncated or incomplete."
msgstr "Изображението във формат ANI е орязано или непълно."

#: cdk-pixbuf/io-ani.c:670
msgctxt "image format"
msgid "Windows animated cursor"
msgstr "Анимиран курсор за Windows"

#: cdk-pixbuf/io-bmp.c:231 cdk-pixbuf/io-bmp.c:269 cdk-pixbuf/io-bmp.c:376
#: cdk-pixbuf/io-bmp.c:403 cdk-pixbuf/io-bmp.c:428 cdk-pixbuf/io-bmp.c:463
#: cdk-pixbuf/io-bmp.c:485 cdk-pixbuf/io-bmp.c:563
msgid "BMP image has bogus header data"
msgstr "Изображението във формат BMP е с неправилна заглавна част"

#: cdk-pixbuf/io-bmp.c:242 cdk-pixbuf/io-bmp.c:498
msgid "Not enough memory to load bitmap image"
msgstr "Недостатъчно памет, за да се зареди изображение във формат BMP"

#: cdk-pixbuf/io-bmp.c:333
msgid "BMP image has unsupported header size"
msgstr ""
"Такъв размер на заглавната част на изображението във формат BMP не се "
"поддържа"

#: cdk-pixbuf/io-bmp.c:343
msgid "BMP image has unsupported depth"
msgstr "Неподдържана дълбочина на цвета за файла във формат BMP"

#: cdk-pixbuf/io-bmp.c:358
msgid "BMP image has oversize palette"
msgstr "Неподдържан размер на палитрата за файла във формат BMP"

#: cdk-pixbuf/io-bmp.c:390
msgid "Topdown BMP images cannot be compressed"
msgstr ""
"Изображения във формат BMP с обратен запис (отгоре-надолу, а не обратно) не "
"може да се компресират"

#: cdk-pixbuf/io-bmp.c:415
msgid "BMP image width too large"
msgstr "Прекалено голяма широчина на изображения във формат BMP"

#: cdk-pixbuf/io-bmp.c:792 cdk-pixbuf/io-png.c:564 cdk-pixbuf/io-pnm.c:722
#: cdk-pixbuf/io-pnm.c:879
msgid "Premature end-of-file encountered"
msgstr "Преждевременно се стигна до знак „край на файл“"

#: cdk-pixbuf/io-bmp.c:1313
msgid "Error while decoding colormap"
msgstr "Грешка при декодиране на цветовата карта"

#: cdk-pixbuf/io-bmp.c:1376 cdk-pixbuf/io-bmp.c:1388
msgid "Image is too wide for BMP format."
msgstr "Изображението е прекалено широко за формат BMP."

#: cdk-pixbuf/io-bmp.c:1421
msgid "Couldn’t allocate memory for saving BMP file"
msgstr "Недостатъчно памет за запазване на файл във формат BMP"

#: cdk-pixbuf/io-bmp.c:1462
msgid "Couldn’t write to BMP file"
msgstr "Неуспешен запис във файл във формат BMP"

#: cdk-pixbuf/io-bmp.c:1515 cdk-pixbuf/io-gdip-bmp.c:83
msgctxt "image format"
msgid "BMP"
msgstr "BMP"

#: cdk-pixbuf/io-gdip-emf.c:61
msgctxt "image format"
msgid "EMF"
msgstr "EMF"

#: cdk-pixbuf/io-gdip-gif.c:81 cdk-pixbuf/io-gif.c:1037
msgctxt "image format"
msgid "GIF"
msgstr "GIF"

#: cdk-pixbuf/io-gdip-ico.c:60 cdk-pixbuf/io-ico.c:1412
msgctxt "image format"
msgid "Windows icon"
msgstr "ICO"

#: cdk-pixbuf/io-gdip-jpeg.c:54 cdk-pixbuf/io-jpeg.c:1391
#, c-format
msgid ""
"JPEG quality must be a value between 0 and 100; value “%s” could not be "
"parsed."
msgstr ""
"Качеството за изображението във формат JPEG трябва да бъде между 0 и 100. "
"Стойността „%s“ не може да бъде анализирана."

#: cdk-pixbuf/io-gdip-jpeg.c:69 cdk-pixbuf/io-jpeg.c:1407
#, c-format
msgid ""
"JPEG quality must be a value between 0 and 100; value “%d” is not allowed."
msgstr ""
"Качеството за изображението във формат JPEG трябва да бъде между 0 и 100. "
"Стойността %d не е позволена"

#: cdk-pixbuf/io-gdip-jpeg.c:147 cdk-pixbuf/io-jpeg.c:1691
msgctxt "image format"
msgid "JPEG"
msgstr "JPEG"

#: cdk-pixbuf/io-gdip-tiff.c:83 cdk-pixbuf/io-tiff.c:1087
msgctxt "image format"
msgid "TIFF"
msgstr "TIFF"

#: cdk-pixbuf/io-gdip-utils.c:155
#, c-format
msgid "Could not allocate memory: %s"
msgstr "Недостатъчно памет за заглавна част: %s"

#: cdk-pixbuf/io-gdip-utils.c:180 cdk-pixbuf/io-gdip-utils.c:294
#: cdk-pixbuf/io-gdip-utils.c:334
#, c-format
msgid "Could not create stream: %s"
msgstr "Не може да се създаде поток: %s"

#: cdk-pixbuf/io-gdip-utils.c:194
#, c-format
msgid "Could not seek stream: %s"
msgstr "Не може да се търси в потока: %s"

#: cdk-pixbuf/io-gdip-utils.c:206
#, c-format
msgid "Could not read from stream: %s"
msgstr "Не може да се чете от потока: %s"

#: cdk-pixbuf/io-gdip-utils.c:620
msgid "Couldn’t load bitmap"
msgstr "Изображението във формат BMP не може да бъде заредено"

#: cdk-pixbuf/io-gdip-utils.c:776
msgid "Couldn’t load metafile"
msgstr "Мета-файлът не може да бъде зареден"

#: cdk-pixbuf/io-gdip-utils.c:881
msgid "Unsupported image format for GDI+"
msgstr "Форматът на изображението не се поддържа от GDI+"

#: cdk-pixbuf/io-gdip-utils.c:888
msgid "Couldn’t save"
msgstr "Грешка при запазване"

#: cdk-pixbuf/io-gdip-wmf.c:60
msgctxt "image format"
msgid "WMF"
msgstr "WMF"

#: cdk-pixbuf/io-gif.c:158
#, c-format
msgid "Failure reading GIF: %s"
msgstr "Неуспешно четене на GIF: %s "

#: cdk-pixbuf/io-gif.c:381 cdk-pixbuf/io-gif.c:848 cdk-pixbuf/io-gif.c:901
#: cdk-pixbuf/io-gif.c:974
msgid "Not enough memory to load GIF file"
msgstr "Недостатъчно памет за зареждане на файла във формат GIF"

#: cdk-pixbuf/io-gif.c:507
msgid "GIF image is corrupt (incorrect LZW compression)"
msgstr "Файлът във формат GIF е повреден (грешна компресия на LZW)"

#: cdk-pixbuf/io-gif.c:543
msgid "File does not appear to be a GIF file"
msgstr "Файлът не изглежда да е във формат GIF"

#: cdk-pixbuf/io-gif.c:558
#, c-format
msgid "Version %s of the GIF file format is not supported"
msgstr "Не се поддържа версията %s на форма̀та за файлове GIF"

#: cdk-pixbuf/io-gif.c:587
msgid "Resulting GIF image has zero size"
msgstr "Полученото изображение във формат GIF е с нулев размер"

#: cdk-pixbuf/io-gif.c:657
msgid ""
"GIF image has no global colormap, and a frame inside it has no local "
"colormap."
msgstr ""
"Липсва глобална цветова палитра в изображението във формат GIF, както и "
"локална цветова палитра за някой от кадрите в него."

#: cdk-pixbuf/io-gif.c:861 cdk-pixbuf/io-gif.c:986
msgid "GIF file was missing some data (perhaps it was truncated somehow?)"
msgstr ""
"Липсват част от данните на файла във формат GIF (може би файлът не е цял)."

#: cdk-pixbuf/io-gif.c:920
msgid "GIF image was truncated or incomplete."
msgstr "Изображението във формат GIF е орязано или непълно."

#: cdk-pixbuf/io-gif.c:927
msgid "Not all frames of the GIF image were loaded."
msgstr "Някои кадри от изображението във формат GIF не бяха заредени."

#: cdk-pixbuf/io-icns.c:363
#, c-format
msgid "Error reading ICNS image: %s"
msgstr "Грешка при четене на изображение във формат ICNS: %s"

#: cdk-pixbuf/io-icns.c:380 cdk-pixbuf/io-icns.c:461
msgid "Could not decode ICNS file"
msgstr "Изображението във формат ICNS не може да бъде декодирано"

#: cdk-pixbuf/io-icns.c:517
msgctxt "image format"
msgid "MacOS X icon"
msgstr "Икона за MacOS X"

#: cdk-pixbuf/io-ico.c:238 cdk-pixbuf/io-ico.c:252 cdk-pixbuf/io-ico.c:342
#: cdk-pixbuf/io-ico.c:426 cdk-pixbuf/io-ico.c:451
#, c-format
msgid "Invalid header in icon (%s)"
msgstr "Грешна заглавна част в иконата (%s)"

#: cdk-pixbuf/io-ico.c:268 cdk-pixbuf/io-ico.c:355 cdk-pixbuf/io-ico.c:461
#: cdk-pixbuf/io-ico.c:504 cdk-pixbuf/io-ico.c:532
msgid "Not enough memory to load icon"
msgstr "Недостатъчно памет за зареждане на иконата"

#: cdk-pixbuf/io-ico.c:386
msgid "Invalid header in icon"
msgstr "Грешна заглавна част в иконата"

#: cdk-pixbuf/io-ico.c:387
msgid "Compressed icons are not supported"
msgstr "Не се поддържат компресирани икони"

#: cdk-pixbuf/io-ico.c:489
msgid "Unsupported icon type"
msgstr "Неподдържан вид икона"

#: cdk-pixbuf/io-ico.c:583
msgid "Not enough memory to load ICO file"
msgstr "Недостатъчно памет за зареждане на файл във формат ICO"

#: cdk-pixbuf/io-ico.c:629
msgid "ICO image was truncated or incomplete."
msgstr "Изображението във формат ICO е орязано или непълно."

#: cdk-pixbuf/io-ico.c:1070
msgid "Image too large to be saved as ICO"
msgstr "Изображението е твърде голямо, за да бъде запазено във формат ICO"

#: cdk-pixbuf/io-ico.c:1081
msgid "Cursor hotspot outside image"
msgstr "Горещата точка на показалеца е извън изображението"

#: cdk-pixbuf/io-ico.c:1104
#, c-format
msgid "Unsupported depth for ICO file: %d"
msgstr "Неподдържана дълбочина на цвета за файла във формат ICO: %d"

#: cdk-pixbuf/io-jpeg.c:129
#, c-format
msgid "Error interpreting JPEG image file (%s)"
msgstr "Грешка при интерпретацията на изображението във формат JPEG (%s)"

#: cdk-pixbuf/io-jpeg.c:638
msgid ""
"Insufficient memory to load image, try exiting some applications to free "
"memory"
msgstr ""
"Недостатъчно памет за зареждане на изображението. Спрете някои програми, за "
"да освободите памет."

#: cdk-pixbuf/io-jpeg.c:711 cdk-pixbuf/io-jpeg.c:956
#, c-format
msgid "Unsupported JPEG color space (%s)"
msgstr "Неподдържано цветово пространство за форма̀та JPEG (%s)"

#: cdk-pixbuf/io-jpeg.c:834 cdk-pixbuf/io-jpeg.c:1151 cdk-pixbuf/io-jpeg.c:1498
#: cdk-pixbuf/io-jpeg.c:1508
msgid "Couldn’t allocate memory for loading JPEG file"
msgstr "Недостатъчно памет за зареждане на файл във формат JPEG"

#: cdk-pixbuf/io-jpeg.c:1109
