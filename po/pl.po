#: cdk-pixbuf/cdk-pixbuf-animation.c:175 cdk-pixbuf/cdk-pixbuf-io.c:1125
#: cdk-pixbuf/cdk-pixbuf-io.c:1387
#, c-format
msgid "Failed to open file “%s”: %s"
msgstr "Otwarcie pliku „%s” się nie powiodło: %s"

#: cdk-pixbuf/cdk-pixbuf-animation.c:188 cdk-pixbuf/cdk-pixbuf-io.c:992
#, c-format
msgid "Image file “%s” contains no data"
msgstr "Plik obrazu „%s” nie zawiera danych"

#: cdk-pixbuf/cdk-pixbuf-animation.c:226
#, c-format
msgid ""
"Failed to load animation “%s”: reason not known, probably a corrupt "
"animation file"
msgstr ""
"Wczytanie animacji „%s” się nie powiodło: przyczyna nieznana; prawdopodobnie "
"uszkodzony plik animacji"

#: cdk-pixbuf/cdk-pixbuf-animation.c:294 cdk-pixbuf/cdk-pixbuf-io.c:1161
#: cdk-pixbuf/cdk-pixbuf-io.c:1439
#, c-format
msgid ""
"Failed to load image “%s”: reason not known, probably a corrupt image file"
msgstr ""
"Wczytanie obrazu „%s” się nie powiodło: przyczyna nieznana; prawdopodobnie "
"uszkodzony plik obrazu"

#: cdk-pixbuf/cdk-pixbuf.c:237
msgid "Number of Channels"
msgstr "Liczba kanałów"

#: cdk-pixbuf/cdk-pixbuf.c:238
msgid "The number of samples per pixel"
msgstr "Liczba próbek na piksel"

#: cdk-pixbuf/cdk-pixbuf.c:247
msgid "Colorspace"
msgstr "Przestrzeń kolorów"

#: cdk-pixbuf/cdk-pixbuf.c:248
msgid "The colorspace in which the samples are interpreted"
msgstr "Przestrzeń kolorów, w której próbki są interpretowane"

#: cdk-pixbuf/cdk-pixbuf.c:256
msgid "Has Alpha"
msgstr "Ma kanał alfa"

#: cdk-pixbuf/cdk-pixbuf.c:257
msgid "Whether the pixbuf has an alpha channel"
msgstr "Czy bufor piksmapy ma kanał alfa"

#: cdk-pixbuf/cdk-pixbuf.c:270
msgid "Bits per Sample"
msgstr "Bity na próbkę"

#: cdk-pixbuf/cdk-pixbuf.c:271
msgid "The number of bits per sample"
msgstr "Liczba bitów na próbkę"

#: cdk-pixbuf/cdk-pixbuf.c:280
msgid "Width"
msgstr "Szerokość"

#: cdk-pixbuf/cdk-pixbuf.c:281
msgid "The number of columns of the pixbuf"
msgstr "Liczba kolumn bufora piksmapy"

#: cdk-pixbuf/cdk-pixbuf.c:290
msgid "Height"
msgstr "Wysokość"

#: cdk-pixbuf/cdk-pixbuf.c:291
msgid "The number of rows of the pixbuf"
msgstr "Liczba rzędów bufora piksmapy"

#: cdk-pixbuf/cdk-pixbuf.c:307
msgid "Rowstride"
msgstr "Odstęp między rzędami"

#: cdk-pixbuf/cdk-pixbuf.c:308
msgid ""
"The number of bytes between the start of a row and the start of the next row"
msgstr "Liczba bajtów między początkiem rzędu a początkiem następnego"

#: cdk-pixbuf/cdk-pixbuf.c:317
msgid "Pixels"
msgstr "Piksele"

#: cdk-pixbuf/cdk-pixbuf.c:318
msgid "A pointer to the pixel data of the pixbuf"
msgstr "Wskaźnik danych pikseli bufora piksmapy"

#: cdk-pixbuf/cdk-pixbuf.c:332
msgid "Pixel Bytes"
msgstr "Bajty piksela"

#: cdk-pixbuf/cdk-pixbuf.c:333
msgid "Readonly pixel data"
msgstr "Dane piksela tylko do odczytu"

#: cdk-pixbuf/cdk-pixbuf-io.c:812
#, c-format
msgid "Unable to load image-loading module: %s: %s"
msgstr "Nie można wczytać modułu wczytującego obrazy: %s: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:827
#, c-format
msgid ""
"Image-loading module %s does not export the proper interface; perhaps it’s "
"from a different cdk-pixbuf version?"
msgstr ""
"Moduł %s do wczytywania obrazów nie eksportuje właściwego interfejsu. Być "
"może pochodzi on z innej wersji biblioteki cdk-pixbuf."

#: cdk-pixbuf/cdk-pixbuf-io.c:836 cdk-pixbuf/cdk-pixbuf-io.c:879
#, c-format
msgid "Image type “%s” is not supported"
msgstr "Obrazy typu „%s” nie są obsługiwane"

#: cdk-pixbuf/cdk-pixbuf-io.c:964
#, c-format
msgid "Couldn’t recognize the image file format for file “%s”"
msgstr "Nie można rozpoznać formatu obrazu w pliku „%s”"

#: cdk-pixbuf/cdk-pixbuf-io.c:972
msgid "Unrecognized image file format"
msgstr "Nierozpoznany format pliku obrazu"

#: cdk-pixbuf/cdk-pixbuf-io.c:1172
#, c-format
msgid "Failed to load image “%s”: %s"
msgstr "Wczytanie obrazu „%s” się nie powiodło: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2242 cdk-pixbuf/io-gdip-utils.c:840
#, c-format
msgid "Error writing to image file: %s"
msgstr "Błąd podczas zapisywania do pliku obrazu: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2284 cdk-pixbuf/cdk-pixbuf-io.c:2405
#, c-format
msgid "This build of cdk-pixbuf does not support saving the image format: %s"
msgstr ""
"Ta kopia biblioteki cdk-pixbuf nie obsługuje zapisywania obrazu w formacie: "
"%s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2315
msgid "Insufficient memory to save image to callback"
msgstr "Brak pamięci do zapisu obrazu do funkcji zwrotnej"

#: cdk-pixbuf/cdk-pixbuf-io.c:2328
msgid "Failed to open temporary file"
msgstr "Otwarcie pliku tymczasowego się nie powiodło"

#: cdk-pixbuf/cdk-pixbuf-io.c:2351
msgid "Failed to read from temporary file"
msgstr "Odczytanie pliku tymczasowego się nie powiodło"

#: cdk-pixbuf/cdk-pixbuf-io.c:2561
#, c-format
msgid "Failed to open “%s” for writing: %s"
msgstr "Otwarcie „%s” do zapisania się nie powiodło: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2587
#, c-format
msgid ""
"Failed to close “%s” while writing image, all data may not have been saved: "
"%s"
msgstr ""
"Zamknięcie pliku „%s” po zapisaniu w nim obrazu się nie powiodło. Część "
"danych mogła nie zostać zapisana: %s"

#: cdk-pixbuf/cdk-pixbuf-io.c:2808 cdk-pixbuf/cdk-pixbuf-io.c:2860
msgid "Insufficient memory to save image into a buffer"
msgstr "Brak pamięci do zapisu obrazu do bufora"

#: cdk-pixbuf/cdk-pixbuf-io.c:2906
msgid "Error writing to image stream"
msgstr "Błąd podczas zapisywania do strumienia obrazu"

#: cdk-pixbuf/cdk-pixbuf-loader.c:406
#, c-format
msgid ""
"Internal error: Image loader module “%s” failed to complete an operation, "
"but didn’t give a reason for the failure"
msgstr ""
"Błąd wewnętrzny: moduł wczytujący obrazy „%s” nie ukończył działania, nie "
"podając przyczyny niepowodzenia"

#: cdk-pixbuf/cdk-pixbuf-loader.c:448
#, c-format
msgid "Incremental loading of image type “%s” is not supported"
msgstr ""
"Funkcja przyrostowego wczytywania obrazów typu „%s” nie jest obsługiwana"

#: cdk-pixbuf/cdk-pixbuf-simple-anim.c:162
msgid "Loop"
msgstr "Pętla"

#: cdk-pixbuf/cdk-pixbuf-simple-anim.c:163
msgid "Whether the animation should loop when it reaches the end"
msgstr "Czy animacja powinna być zapętlona"

#: cdk-pixbuf/cdk-pixdata.c:165
msgid "Image header corrupt"
msgstr "Uszkodzony nagłówek obrazu"

#: cdk-pixbuf/cdk-pixdata.c:170
msgid "Image format unknown"
msgstr "Nieznany format obrazu"

#: cdk-pixbuf/cdk-pixdata.c:175 cdk-pixbuf/cdk-pixdata.c:470
#: cdk-pixbuf/cdk-pixdata.c:480 cdk-pixbuf/cdk-pixdata.c:576
msgid "Image pixel data corrupt"
msgstr "Uszkodzone dane o pikselach obrazu"

#: cdk-pixbuf/cdk-pixdata.c:492
#, c-format
msgid "failed to allocate image buffer of %u byte"
msgid_plural "failed to allocate image buffer of %u bytes"
msgstr[0] "przydzielenie %u bajtu dla bufora odczytu pliku się nie powiodło"
msgstr[1] "przydzielenie %u bajtów dla bufora odczytu pliku się nie powiodło"
msgstr[2] "przydzielenie %u bajtów dla bufora odczytu pliku się nie powiodło"

#: cdk-pixbuf/io-ani.c:239
msgid "Unexpected icon chunk in animation"
msgstr "Nieobsługiwany fragment ikony w animacji"

#: cdk-pixbuf/io-ani.c:337 cdk-pixbuf/io-ani.c:395 cdk-pixbuf/io-ani.c:421
#: cdk-pixbuf/io-ani.c:444 cdk-pixbuf/io-ani.c:471 cdk-pixbuf/io-ani.c:558
msgid "Invalid header in animation"
msgstr "Nieprawidłowy nagłówek w animacji"

#: cdk-pixbuf/io-ani.c:347 cdk-pixbuf/io-ani.c:369 cdk-pixbuf/io-ani.c:453
#: cdk-pixbuf/io-ani.c:480 cdk-pixbuf/io-ani.c:531 cdk-pixbuf/io-ani.c:607
msgid "Not enough memory to load animation"
msgstr "Brak pamięci do wczytania animacji"

#: cdk-pixbuf/io-ani.c:387 cdk-pixbuf/io-ani.c:413 cdk-pixbuf/io-ani.c:432
msgid "Malformed chunk in animation"
msgstr "Uszkodzony fragment animacji"

#: cdk-pixbuf/io-ani.c:629
msgid "ANI image was truncated or incomplete."
msgstr "Plik ANI został obcięty lub jest niekompletny."

#: cdk-pixbuf/io-ani.c:670
msgctxt "image format"
msgid "Windows animated cursor"
msgstr "Animowany kursor systemu Windows"

#: cdk-pixbuf/io-bmp.c:231 cdk-pixbuf/io-bmp.c:269 cdk-pixbuf/io-bmp.c:376
#: cdk-pixbuf/io-bmp.c:403 cdk-pixbuf/io-bmp.c:428 cdk-pixbuf/io-bmp.c:463
#: cdk-pixbuf/io-bmp.c:485 cdk-pixbuf/io-bmp.c:563
msgid "BMP image has bogus header data"
msgstr "Błędny nagłówek obrazu BMP"

#: cdk-pixbuf/io-bmp.c:242 cdk-pixbuf/io-bmp.c:498
msgid "Not enough memory to load bitmap image"
msgstr "Brak pamięci na wczytanie bitmapy z pliku"

#: cdk-pixbuf/io-bmp.c:333
msgid "BMP image has unsupported header size"
msgstr "Obraz BMP zawiera nagłówek o nieobsługiwanym rozmiarze"

#: cdk-pixbuf/io-bmp.c:343
msgid "BMP image has unsupported depth"
msgstr "Obraz BMP zawiera nieobsługiwaną głębię"

#: cdk-pixbuf/io-bmp.c:358
msgid "BMP image has oversize palette"
msgstr "Obraz BMP zawiera za dużą paletę"

#: cdk-pixbuf/io-bmp.c:390
msgid "Topdown BMP images cannot be compressed"
msgstr "Zstępujące (top-down) obrazy BMP nie mogą być skompresowane"

#: cdk-pixbuf/io-bmp.c:415
msgid "BMP image width too large"
msgstr "Szerokość obrazu BMP jest za duża"

#: cdk-pixbuf/io-bmp.c:792 cdk-pixbuf/io-png.c:564 cdk-pixbuf/io-pnm.c:722
#: cdk-pixbuf/io-pnm.c:879
msgid "Premature end-of-file encountered"
msgstr "Przedwcześnie wystąpił koniec pliku"

#: cdk-pixbuf/io-bmp.c:1313
#, c-format
msgid "Error while decoding colormap"
msgstr "Błąd podczas dekodowania palety kolorów"

#: cdk-pixbuf/io-bmp.c:1376 cdk-pixbuf/io-bmp.c:1388
msgid "Image is too wide for BMP format."
msgstr "Obraz jest za szeroki dla formatu BMP."

#: cdk-pixbuf/io-bmp.c:1421
msgid "Couldn’t allocate memory for saving BMP file"
msgstr "Nie można przydzielić pamięci do zapisu pliku BMP"

#: cdk-pixbuf/io-bmp.c:1462
msgid "Couldn’t write to BMP file"
msgstr "Nie można zapisać do pliku BMP"

#: cdk-pixbuf/io-bmp.c:1515 cdk-pixbuf/io-gdip-bmp.c:83
msgctxt "image format"
msgid "BMP"
msgstr "BMP"

#: cdk-pixbuf/io-gdip-emf.c:61
msgctxt "image format"
msgid "EMF"
msgstr "EMF"

#: cdk-pixbuf/io-gdip-gif.c:81 cdk-pixbuf/io-gif.c:1043
msgctxt "image format"
msgid "GIF"
msgstr "GIF"

#: cdk-pixbuf/io-gdip-ico.c:60 cdk-pixbuf/io-ico.c:1412
msgctxt "image format"
msgid "Windows icon"
msgstr "Ikona systemu Windows"

#: cdk-pixbuf/io-gdip-jpeg.c:54 cdk-pixbuf/io-jpeg.c:1382
#, c-format
msgid ""
"JPEG quality must be a value between 0 and 100; value “%s” could not be "
"parsed."
msgstr ""
"Jakość obrazu JPEG musi być wartością między 0 a 100. Wartość „%s” nie może "
"zostać przetworzona."

#: cdk-pixbuf/io-gdip-jpeg.c:69 cdk-pixbuf/io-jpeg.c:1398
#, c-format
msgid ""
"JPEG quality must be a value between 0 and 100; value “%d” is not allowed."
msgstr ""
"Jakość obrazu JPEG musi być wartością między 0 a 100. Wartość „%d” nie jest "
"dozwolona."

#: cdk-pixbuf/io-gdip-jpeg.c:147 cdk-pixbuf/io-jpeg.c:1682
msgctxt "image format"
msgid "JPEG"
msgstr "JPEG"

#: cdk-pixbuf/io-gdip-tiff.c:83 cdk-pixbuf/io-tiff.c:1086
msgctxt "image format"
msgid "TIFF"
msgstr "TIFF"

#: cdk-pixbuf/io-gdip-utils.c:155
#, c-format
msgid "Could not allocate memory: %s"
msgstr "Nie można przydzielić pamięci: %s"

#: cdk-pixbuf/io-gdip-utils.c:180 cdk-pixbuf/io-gdip-utils.c:294
#: cdk-pixbuf/io-gdip-utils.c:334
#, c-format
msgid "Could not create stream: %s"
msgstr "Nie można utworzyć strumienia: %s"

#: cdk-pixbuf/io-gdip-utils.c:194
#, c-format
msgid "Could not seek stream: %s"
msgstr "Nie można przewijać strumienia: %s"

#: cdk-pixbuf/io-gdip-utils.c:206
#, c-format
msgid "Could not read from stream: %s"
msgstr "Nie można odczytać ze strumienia: %s"

#: cdk-pixbuf/io-gdip-utils.c:620
msgid "Couldn’t load bitmap"
msgstr "Nie można wczytać bitmapy"

#: cdk-pixbuf/io-gdip-utils.c:776
msgid "Couldn’t load metafile"
msgstr "Nie można wczytać metapliku"

#: cdk-pixbuf/io-gdip-utils.c:881
msgid "Unsupported image format for GDI+"
msgstr "Nieobsługiwany typ obrazu dla biblioteki GDI+"

#: cdk-pixbuf/io-gdip-utils.c:888
msgid "Couldn’t save"
msgstr "Nie można zapisać"

#: cdk-pixbuf/io-gdip-wmf.c:60
msgctxt "image format"
msgid "WMF"
msgstr "WMF"

#: cdk-pixbuf/io-gif.c:158
#, c-format
msgid "Failure reading GIF: %s"
msgstr "Odczytanie obrazu GIF się nie powiodło: %s"

#: cdk-pixbuf/io-gif.c:381 cdk-pixbuf/io-gif.c:854 cdk-pixbuf/io-gif.c:907
#: cdk-pixbuf/io-gif.c:980
msgid "Not enough memory to load GIF file"
msgstr "Brak pamięci na wczytanie pliku GIF"

#: cdk-pixbuf/io-gif.c:507
msgid "GIF image is corrupt (incorrect LZW compression)"
msgstr "Obraz GIF jest uszkodzony (niepoprawna kompresja LZW)"

#: cdk-pixbuf/io-gif.c:536
msgid "File does not appear to be a GIF file"
msgstr "Plik nie jest plikiem GIF"

#: cdk-pixbuf/io-gif.c:551
#, c-format
msgid "Version %s of the GIF file format is not supported"
msgstr "Format GIF w wersji %s nie jest obsługiwany"

#: cdk-pixbuf/io-gif.c:586
msgid "Resulting GIF image has zero size"
msgstr "Rozmiar wynikowego obrazu GIF wynosi zero"

#: cdk-pixbuf/io-gif.c:664
msgid ""
"GIF image has no global colormap, and a frame inside it has no local "
"colormap."
msgstr ""
"Obraz GIF nie ma globalnej palety kolorów, a klatka wewnątrz nie ma palety "
"lokalnej."

#: cdk-pixbuf/io-gif.c:867 cdk-pixbuf/io-gif.c:992
msgid "GIF file was missing some data (perhaps it was truncated somehow?)"
msgstr ""
"Plik GIF nie zawiera wszystkich wymaganych danych (może został obcięty?)"

#: cdk-pixbuf/io-gif.c:926
msgid "GIF image was truncated or incomplete."
msgstr "Plik GIF został obcięty lub jest niekompletny."

#: cdk-pixbuf/io-gif.c:933
msgid "Not all frames of the GIF image were loaded."
msgstr "Nie wczytano wszystkich klatek obrazu GIF."

#: cdk-pixbuf/io-icns.c:363
#, c-format
msgid "Error reading ICNS image: %s"
msgstr "Błąd podczas odczytywania pliku ICNS: %s"

#: cdk-pixbuf/io-icns.c:380 cdk-pixbuf/io-icns.c:461
msgid "Could not decode ICNS file"
msgstr "Nie można zdekodować pliku ICNS"

#: cdk-pixbuf/io-icns.c:517
msgctxt "image format"
msgid "MacOS X icon"
msgstr "Ikona systemu Mac OS X"

#: cdk-pixbuf/io-ico.c:238 cdk-pixbuf/io-ico.c:252 cdk-pixbuf/io-ico.c:342
#: cdk-pixbuf/io-ico.c:426 cdk-pixbuf/io-ico.c:451
#, c-format
msgid "Invalid header in icon (%s)"
msgstr "Nieprawidłowy nagłówek ikony (%s)"

#: cdk-pixbuf/io-ico.c:268 cdk-pixbuf/io-ico.c:355 cdk-pixbuf/io-ico.c:461
#: cdk-pixbuf/io-ico.c:504 cdk-pixbuf/io-ico.c:532
msgid "Not enough memory to load icon"
msgstr "Brak pamięci na wczytanie ikony"

#: cdk-pixbuf/io-ico.c:386
msgid "Invalid header in icon"
msgstr "Nieprawidłowy nagłówek ikony"

#: cdk-pixbuf/io-ico.c:387
msgid "Compressed icons are not supported"
msgstr "Skompresowane ikony nie są obsługiwane"

#: cdk-pixbuf/io-ico.c:489
msgid "Unsupported icon type"
msgstr "Nieobsługiwany typ ikony"

#: cdk-pixbuf/io-ico.c:583
msgid "Not enough memory to load ICO file"
msgstr "Brak pamięci na wczytanie pliku ICO"

#: cdk-pixbuf/io-ico.c:629
msgid "ICO image was truncated or incomplete."
msgstr "Plik ICO został obcięty lub jest niekompletny."

#: cdk-pixbuf/io-ico.c:1070
msgid "Image too large to be saved as ICO"
msgstr "Obraz jest za duży, aby mógł zostać zapisany jako ICO"

#: cdk-pixbuf/io-ico.c:1081
msgid "Cursor hotspot outside image"
msgstr "Gorący punkt poza obrazem"

#: cdk-pixbuf/io-ico.c:1104
#, c-format
msgid "Unsupported depth for ICO file: %d"
msgstr "Nieobsługiwana głębia dla pliku ICO: %d"

#: cdk-pixbuf/io-jpeg.c:129
#, c-format
msgid "Error interpreting JPEG image file (%s)"
msgstr "Błąd podczas interpretowania pliku obrazu JPEG (%s)"

#: cdk-pixbuf/io-jpeg.c:637
msgid ""
"Insufficient memory to load image, try exiting some applications to free "
"memory"
msgstr ""
"Brak pamięci na wczytanie obrazu. Proszę spróbować zakończyć działanie "
"części programów, aby zwolnić pamięć"

#: cdk-pixbuf/io-jpeg.c:710 cdk-pixbuf/io-jpeg.c:947
#, c-format
msgid "Unsupported JPEG color space (%s)"
msgstr "Nieobsługiwana przestrzeń kolorów w pliku JPEG (%s)"

#: cdk-pixbuf/io-jpeg.c:825 cdk-pixbuf/io-jpeg.c:1142 cdk-pixbuf/io-jpeg.c:1489
#: cdk-pixbuf/io-jpeg.c:1499
msgid "Couldn’t allocate memory for loading JPEG file"
msgstr "Nie można przydzielić pamięci do wczytania pliku JPEG"

#: cdk-pixbuf/io-jpeg.c:1100
msgid "Transformed JPEG has zero width or height."
msgstr "Przekształcony JPEG ma zerową szerokość lub wysokość."

#: cdk-pixbuf/io-jpeg.c:1126
#, c-format
msgid "Unsupported number of color components (%d)"
msgstr "Nieobsługiwana liczba składowych kolorów (%d)"

#: cdk-pixbuf/io-jpeg.c:1419
#, c-format
msgid ""
"JPEG x-dpi must be a value between 1 and 65535; value “%s” is not allowed."
msgstr ""
"x-dpi obrazu JPEG musi być wartością między 1 a 65535. Wartość „%s” nie jest "
"dozwolona."

#: cdk-pixbuf/io-jpeg.c:1440
#, c-format
msgid ""
"JPEG y-dpi must be a value between 1 and 65535; value “%s” is not allowed."
msgstr ""
"y-dpi obrazu JPEG musi być wartością między 1 a 65535. Wartość „%s” nie jest "
"dozwolona."

#: cdk-pixbuf/io-jpeg.c:1454
#, c-format
msgid "Color profile has invalid length “%u”."
msgstr "Profil kolorów ma nieprawidłową długość „%u”."

#: cdk-pixbuf/io-png.c:63
msgid "Bits per channel of PNG image is invalid."
msgstr "Liczba bitów na kanał obrazu PNG jest nieprawidłowa."

